## Lean .gitignore for the Twilight solution (C++ WebView2 host + Vite/TS frontend).
## Frontend-specific ignores live in twilight-hammer/.gitignore.

# Visual Studio cache / user-specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Build output directories
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/

# Installer output
#   Output/ = Inno Setup default OutputDir
#   dist/   = publish.ps1 / Publish MSBuild target
[Oo]utput/
[Dd]ist/

# C/C++ build intermediates
*.obj
*.pch
*.pdb
*.idb
*.ipdb
*.ilk
*.iobj
*.tlog
*.lastbuildstate
*.log

# Visual Studio resource editor cache
*.aps

# NuGet packages (restored on build); keep build/ which is used as an MSBuild target
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nupkg
